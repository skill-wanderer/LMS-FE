# Public site URL (used for SSR redirect URIs behind reverse proxy)
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Keycloak Authentication (optional — leave blank to disable login/register UI)
NUXT_PUBLIC_KEYCLOAK_URL=https://sso.skill-wanderer.com
NUXT_PUBLIC_KEYCLOAK_REALM=skill-wanderer
NUXT_PUBLIC_KEYCLOAK_CLIENT_ID=lms

# Backend API base URL (for lesson completion, progress tracking, etc.)
NUXT_PUBLIC_API_BASE_URL=https://lms-api.skill-wanderer.com

# Lyra Chatbot (Pathfinder API)
NUXT_PUBLIC_PATHFINDER_API_URL=http://localhost:8000
NUXT_PUBLIC_PATHFINDER_DOMAINS=dojo.skill-wanderer.com
NUXT_PUBLIC_PATHFINDER_SESSION_EXPIRY_MINUTES=30
NUXT_PUBLIC_PATHFINDER_SESSION_STORAGE=browser
