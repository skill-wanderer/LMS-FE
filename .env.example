# Keycloak Authentication (optional — leave blank to disable login/register UI)
NUXT_PUBLIC_KEYCLOAK_URL=https://auth.example.com
NUXT_PUBLIC_KEYCLOAK_REALM=my-realm
NUXT_PUBLIC_KEYCLOAK_CLIENT_ID=lms-frontend

# Backend API base URL (for lesson completion, progress tracking, etc.)
NUXT_PUBLIC_API_BASE_URL=http://localhost:8080
